# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env file.

EVE_CLIENT_ID=your_client_id_here
EVE_CLIENT_SECRET=your_client_secret_here
EVE_CALLBACK_URL=http://localhost:8765/callback

# Identifies your app to CCP. Use a real contact (email or Discord handle).
EVE_USER_AGENT=eve-agent/0.1 (your_contact_here)
